# TMDB API Configuration
# Get your free API key from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Data Configuration
DATA_DIR=letterboxd-nashkel-2026-01-08-19-29-utc
CACHE_FILE=tmdb_cache.json
OUTPUT_HTML=letterboxd_stats.html
OUTPUT_JSON=letterboxd_stats_data.json

# Cache Settings
CACHE_EXPIRY_DAYS=30
ENABLE_CACHE=true

# Statistics Settings
TOP_ACTORS_COUNT=20
TOP_DIRECTORS_COUNT=15
TOP_GENRES_COUNT=10
TOP_COUNTRIES_COUNT=10
TOP_LANGUAGES_COUNT=10

# Logging
LOG_LEVEL=INFO
LOG_UNMATCHED_FILMS=true
